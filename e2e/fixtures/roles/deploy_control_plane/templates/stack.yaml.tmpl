---
services:
{% for host in groups['control_plane'] %}
  {{ host }}:
    image: {{ control_plane_image }}
    command: run
    environment:
      - PGEDGE_PEER_ADDRESSES={{ hostvars[host].peer_ip }}
      - PGEDGE_CLIENT_ADDRESSES={{ hostvars[host].external_ip }}
      - PGEDGE_HOST_ID={{ host }}
      - PGEDGE_DATA_DIR=/data/control-plane
      - PGEDGE_DOCKER_SWARM__IMAGE_REPOSITORY_HOST=127.0.0.1:5001/pgedge
      - PGEDGE_ZFS__ENABLED=true
      - PGEDGE_ZFS__POOL=tank/pgedge
      - PGEDGE_ZFS__COMMAND_IMAGE=busybox:latest
{% if host in hostvars['localhost'].worker_hosts %}
      - PGEDGE_ETCD_MODE=client
{% endif %}
    volumes:
      - /data/control-plane:/data/control-plane
      - /var/run/docker.sock:/var/run/docker.sock
    networks:
      - host
    deploy:
      placement:
        constraints:
          - node.hostname == {{ hostvars[host].docker_node_hostname }}
{% endfor %}
networks:
  host:
    name: host
    external: true
